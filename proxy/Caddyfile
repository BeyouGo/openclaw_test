{
  admin off
  auto_https off
}

:8443 {
  @api {
    path /api/*
  }

  handle @api {
    reverse_proxy api:4000
  }

  @protected {
    not path /api/*
    not method OPTIONS
  }

  basicauth @protected {
    {env.BASIC_AUTH_USER} {env.BASIC_AUTH_PASSWORD_HASH}
  }

  handle {
    root * /srv/www
    try_files {path} /index.html
    file_server
  }
}
